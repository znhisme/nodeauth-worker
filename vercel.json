{
  "version": 2,
  "buildCommand": "node scripts/inject_vars.js --platform=vercel",
  "outputDirectory": "frontend/dist",
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}